# Goal
vortex_msgs/LandmarkType type
vortex_msgs/LandmarkSubtype subtype
geometry_msgs/Pose convergence_offset
float64 convergence_threshold
float64 dead_reckoning_threshold
float64 track_loss_timeout_sec

# Convergence mode, controls which mode reference filter will use
uint8 convergence_mode
uint8 FULL_POSE = 0
uint8 ONLY_POSITION = 1
uint8 FORWARD_HEADING = 2
uint8 ONLY_ORIENTATION = 3
---
# Result
bool success
bool landmark_valid
vortex_msgs/Landmark landmark
